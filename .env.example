# Ably API key — sign up free at https://ably.com and paste the key from your app's "API Keys" tab.
ABLY_API_KEY=

# Max turns per agent per campaign. Each agent stops after this many replies.
MAX_TURNS=50

# Optional: path to the agents.yaml config. Defaults to config/agents.yaml.
# CONFIG_FILE=examples/software-engineering/agents.yaml
