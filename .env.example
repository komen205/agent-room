# ---- Transport selection ----
# "ably" (default) uses the hosted Ably service — free tier available at https://ably.com.
# "nats" uses a self-hosted NATS server — `docker compose up -d nats` spins one up locally.
TRANSPORT=ably

# ---- Ably transport ----
# Required when TRANSPORT=ably. Paste the key from your Ably app's "API Keys" tab.
ABLY_API_KEY=

# ---- NATS transport ----
# Required when TRANSPORT=nats. Defaults to the local Docker service on localhost:4222.
NATS_URL=nats://localhost:4222
# NATS_USER=
# NATS_PASS=
# NATS_TOKEN=

# ---- Runtime knobs ----
# Max turns per agent per campaign. Each agent stops after this many replies.
MAX_TURNS=50

# Optional: path to the agents.yaml config. Defaults to config/agents.yaml.
# CONFIG_FILE=examples/software-engineering/agents.yaml
